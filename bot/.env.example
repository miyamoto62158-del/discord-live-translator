# Discord Bot設定
# ↓ ここにあなたのBotトークンを貼り付けてください
DISCORD_TOKEN=your-bot-token-here

# ↓ 【必須】ここにGoogle AI StudioのGemini APIキーを貼り付けてください
# 音声・テキストの超低遅延リアルタイムクラウド翻訳を行うために必須となります（無料枠対応）。
GEMINI_API_KEY=your-gemini-api-key-here

# Webダッシュボードのポート（変更不要）
DASHBOARD_PORT=3000
# クラウド上のダッシュボードの公開URL (例: http://35.200.x.x:3000)
DASHBOARD_URL=http://localhost:3000

# デフォルトの翻訳先言語
DEFAULT_TARGET_LANG=JA

# ノイズゲート閾値 (これ以下の音量の音声は無視されます。デフォルトは 300)
# 誰もしゃべっていないのに誤認識・誤翻訳される場合は 400〜600 等に上げてみてください。
NOISE_THRESHOLD_RMS=300
