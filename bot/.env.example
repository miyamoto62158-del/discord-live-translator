# Discord Bot設定
# ↓ ここにあなたのBotトークンを貼り付けてください
DISCORD_TOKEN=your-bot-token-here

# ↓ ここにDeepL API Freeのキーを貼り付けてください
DEEPL_API_KEY=your-deepl-api-key-here

# Python Transcriberサーバーの設定
# [ハイブリッド構成での利用方法]
# - クラウド側（Bot）：HYBRID_WS_PORT でローカルクライアントからの接続を受け付けます。
# - ローカル側（クライアント）：CLOUD_BOT_WS_URL にクラウドBotのグローバルIPやドメインを指定します。
HYBRID_WS_PORT=8765
CLOUD_BOT_WS_URL=ws://localhost:8765

# Webダッシュボードのポート（変更不要）
DASHBOARD_PORT=3000
# クラウド上のダッシュボードの公開URL (例: http://35.200.x.x:3000)
DASHBOARD_URL=http://localhost:3000

# デフォルトの翻訳先言語
DEFAULT_TARGET_LANG=JA

# ノイズゲート閾値 (これ以下の音量の音声は無視されます。デフォルトは 450)
# 誰もしゃべっていないのに誤認識・誤翻訳される場合は 500〜700 等に上げてみてください。
NOISE_THRESHOLD_RMS=350
