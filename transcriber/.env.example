# ============================================================
# LiveTranslator - GPU Client Settings (Local PC)
# ============================================================
# This is the ONLY setting you need to configure.
# Copy this file to ".env" and set the cloud server URL.
#
# DeepL API key and Discord token are NOT needed here.
# Translation is handled on the cloud server.
# ============================================================

# Cloud Bot WebSocket URL
# Replace with your cloud server's IP or domain
# Example: ws://35.200.x.x:3000/hybrid
CLOUD_BOT_WS_URL=ws://localhost:3000/hybrid
